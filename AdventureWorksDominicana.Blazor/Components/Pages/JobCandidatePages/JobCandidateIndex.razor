@page "/JobCandidate/Index"
@rendermode InteractiveServer

@inject JobCandidateService jobCandidateService;

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between">
            <h3>Contact Types</h3>
            <a class="btn btn-primary bi bi-plus-square" href="/JobCandidate/Create"> Crear</a>
        </div>
        <div class="card-body">
            @* Encabezados *@
            <div class="row">
                <div class="col-3">
                    <label>Desde:</label>
                </div>
                <div class="col-3">
                    <label>Hasta:</label>
                </div>
                <div class="col-3">
                    <label>Filtro:</label>
                </div>
                <div class="col-3">
                    <label>Buscar:</label>
                </div>
            </div>

            @* Inputs *@
            <div class="row pb-3">
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaDesde" />
                </div>
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaHasta" />
                </div>
                <div class="col-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="" disabled selected hidden>Seleccione un filtro...</option>
                        <option value="Nombre">Nombre</option>
                    </select>
                </div>
                <div class="col-3">
                    <div class="input-group">
                        <input class="form-control" type="text" @bind-value="ValorFiltro" placeholder="Buscar..." />
                        <button class="btn btn-primary bi bi-search" type="button" @onclick="Filtrar"></button>
                        <button class="btn btn-outline-primary bi bi-arrow-clockwise" type="button" @onclick="Restablecer"></button>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <QuickGrid Class="table table-striped table-bordered table-hover" Pagination="@pages" Items="ListaVJobCandidate.AsQueryable()" ItemKey="@(j => j.JobCandidateId)">
                    <PropertyColumn Property="@(j => j.JobCandidateId)" Sortable="true" Title="ID" />
                    <TemplateColumn Sortable="true" Title="Nombre Completo">
                        @($"{context.NameFirst} {context.NameLast}")
                    </TemplateColumn>
                    <PropertyColumn Property="@(j => j.Email)" Sortable="true" Title="Email" />
                    <TemplateColumn Title="Habilidades">
                        @(context.Skills?.Length > 50 ? context.Skills.Substring(0, 50) + "..." : context.Skills)
                    </TemplateColumn>
                    <TemplateColumn Sortable="true" Title="Estado">
                        @if (context.BusinessEntityId.HasValue)
                        {
                            <span class="badge bg-success">Contratado</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                    </TemplateColumn>        
                    <TemplateColumn Class="text-center" Title="Acciones">
                        <div class="btn-group btn-group-sm">
                            <a href="/JobCandidate/Details/@context.JobCandidateId" class="btn btn-sm btn-outline-info bi bi-eye"> Ver</a>
            
                            @if (!context.BusinessEntityId.HasValue)
                            {
                                <a href="/JobCandidate/Edit/@context.JobCandidateId" class="btn btn-sm btn-outline-primary bi bi-pencil-square"> Editar</a>
                                <button class="btn btn-sm btn-outline-success bi bi-person-plus"> Contratar</button>
                            }
                        </div>
                    </TemplateColumn>
                </QuickGrid>
            </div>
            @*Pagination*@
            <Paginator State="@pages" />
        </div>
    </div>
</div>

@code {
    public List<VJobCandidate> ListaVJobCandidate { get; set; } = new List<VJobCandidate>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        ListaVJobCandidate = await jobCandidateService.GetListViewPersonal(j => j.JobCandidateId > 0);
        ListaVJobCandidate = ListaVJobCandidate.OrderByDescending(j => j.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<VJobCandidate, bool>> criterio = j => j.JobCandidateId > 0;

        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value && c.ModifiedDate <= fechaHasta);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate <= fechaHasta);
        }
        if (Filtro != "" && ValorFiltro != "")
        {
            if (Filtro == "Nombre")
            {
                criterio = criterio.And(j => j.NameFirst.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }
        ListaVJobCandidate = await jobCandidateService.GetListViewPersonal(criterio);
        ListaVJobCandidate = ListaVJobCandidate.OrderByDescending(c => c.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
