@page "/Department/Index"
@rendermode InteractiveServer
@inject DepartmentService departmentService

<PageTitle>Department Index</PageTitle>
<div class="container">
    <div class="card shadow-lg">
        @*Header*@
        <div class="card-header d-flex justify-content-between bg-primary">
            <h5 class="card-title text-light">Registro de Departamentos</h5>
            <a href="Department/Create" class="btn btn-outline-secondary d-flex gap-2">
                <i class="bi bi-plus-square-fill text-light"></i>
                <span class="text-light">Crear</span>
            </a>
        </div>
        
        <div class="card-body">
            @*Filters*@
            <div class="row">
                <div class="col-6">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" @bind="StartDate"/>
                </div>
                <div class="col-6">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" @bind="EndDate"/>
                </div>
            </div>
            <div class="row">
                <div class="col-6">
                    <label class="form-label">Seleccione una opci&oacute;n</label>
                    <select class="form-select" @bind="Filtro">
                        <option value="">Seleccione una opci&oacute;n</option>
                        <option value="Name">Nombre</option>
                        <option value="GroupName">Nombre del Grupo</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label">Buscar</label>
                    <div class="input-group">
                        <input class="form-control" type="text" placeholder="Buscar..." @bind="ValorFiltro"/>
                        <i class="btn btn-outline-primary bi bi-search" @onclick="Buscar"></i>
                    </div>
                </div>
            </div>
            @*Table*@
            <div class="table-responsive mt-3">
                <QuickGrid Items="DepartmentsList.AsQueryable()" Pagination="@pages" Class="table table-bordered table-hover">
                    <PropertyColumn Property="@(d => d.DepartmentId)" Title="DepartamentoId" Sortable="true" />
                    <PropertyColumn Property="@(d => d.Name)" Title="Nombre" Sortable="true" />
                    <PropertyColumn Property="@(d => d.GroupName)" Title="Nombre del Grupo" Sortable="true" />
                    <TemplateColumn Context="option" Title="Opci&oacute;n">
                        <a href="Department/Edit/@option.DepartmentId" class="btn btn-outline-primary bi bi-pencil"></a>
                    </TemplateColumn>
                </QuickGrid>
                @*Pagination*@
                <Paginator State="@pages"/>
            </div>
        </div>
    </div>
</div>
@code {
    private List<Department> DepartmentsList = new List<Department>();
    private PaginationState pages = new PaginationState{ ItemsPerPage = 5 };
    private string Filtro = string.Empty, ValorFiltro = string.Empty;
    private DateTime? StartDate = DateTime.Today.Date, EndDate = DateTime.Today.Date.AddDays(1);
    protected override async Task OnInitializedAsync()
    {
        DepartmentsList = await departmentService.GetList(p => true);
    }
    private async Task Buscar()
    {
        List<Department> filterList;
        if (StartDate.HasValue && EndDate.HasValue)
            filterList = await departmentService.GetList(d => d.ModifiedDate.Date >= StartDate.Value.Date && d.ModifiedDate.Date <= EndDate.Value.Date);
        else
            filterList = await departmentService.GetList(p => true);
        if (!string.IsNullOrWhiteSpace(Filtro))
            if (Filtro == "Name")
            filterList = filterList.Where(d => d.Name.ToLower().Contains(ValorFiltro.ToLower())).ToList();
            else if (Filtro == "GroupName")
                filterList = filterList.Where(d => d.GroupName.ToLower().Contains(ValorFiltro.ToLower())).ToList();
        DepartmentsList = filterList;
    }
}